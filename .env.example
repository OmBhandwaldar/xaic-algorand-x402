# Generated by `npm run gen-accounts`. Do NOT commit the real .env.
# Each account: MNEMONIC (human backup), ADDR (58-char address), AVM_KEY (base64 64-byte sk).

CONSUMER_MNEMONIC=
CONSUMER_ADDR=
CONSUMER_AVM_KEY=

PRODUCER_MNEMONIC=
PRODUCER_ADDR=
PRODUCER_AVM_KEY=

INSURANCE_MNEMONIC=
INSURANCE_ADDR=
INSURANCE_AVM_KEY=

# Infra (defaults are fine for TestNet)
FACILITATOR_URL=https://facilitator.goplausible.xyz
ALGOD_URL=https://testnet-api.algonode.cloud
PRODUCER_PORT=4021
INSURANCE_PORT=4022

# Groq (OpenAI-compatible) for the real LLM agents
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
