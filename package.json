{
  "name": "aishield-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AIShield - insurance for paid AI tool calls over x402 on Algorand TestNet",
  "scripts": {
    "gen-accounts": "tsx scripts/generate-accounts.ts",
    "optin": "tsx scripts/optin-usdc.ts",
    "balances": "tsx scripts/check-balances.ts",
    "relay": "tsx scripts/relay.ts",
    "producer": "tsx producer/server.ts",
    "insurance": "tsx insurance/server.ts",
    "web": "tsx web/server.ts",
    "start": "concurrently -k -n producer,insurance,web -c blue,magenta,green \"npm:producer\" \"npm:insurance\" \"npm:web\"",
    "demo": "tsx consumer/agent.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@x402-avm/avm": "^2.6.1",
    "@x402-avm/core": "^2.6.1",
    "@x402-avm/express": "^2.6.1",
    "@x402-avm/fetch": "^2.6.1",
    "algosdk": "^3.6.0",
    "concurrently": "^9.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
